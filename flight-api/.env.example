# Firebase Admin SDK
# Opción 1: Path al archivo (desarrollo local)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Opción 2: JSON completo (producción/Render)
# Copia el contenido completo del archivo firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Resend API Key
# Obtén tu API key desde: https://resend.com/api-keys
RESEND_API_KEY=re_123456789

# Base URL del frontend para enlaces
FRONTEND_URL=http://localhost:3000

# CORS Allowed Origins (separados por comas)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
